<Window x:Class="AniTechou.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录 · 追番手账"
        Width="430" Height="470"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei"
        ResizeMode="NoResize">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,12,0,18">
            <TextBlock Text="追番手账"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="AniTechou"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource AppSectionCardStyle}" Padding="22">
            <StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="账号"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="AccountCombo"
                              Height="40"
                              FontSize="14"
                              IsEditable="True"
                              Background="{DynamicResource Surface1Brush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              DisplayMemberPath="UserName"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,22">
                    <TextBlock Text="密码"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Height="40"
                                 Style="{StaticResource AppPasswordBoxStyle}"/>
                </StackPanel>

                <Button Content="登录"
                        Width="100"
                        Height="38"
                        HorizontalAlignment="Center"
                        Style="{StaticResource AppPrimaryButtonStyle}"
                        Click="Login_Click"/>

                <TextBlock Text="还没有账号？注册新账号"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           Cursor="Hand"
                           MouseLeftButtonDown="Register_Click"/>

                <TextBlock x:Name="MessageText"
                           Text=""
                           Foreground="{DynamicResource DangerBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
