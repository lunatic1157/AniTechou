<Window x:Class="AniTechou.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录 · 追番手账"
        Width="400" Height="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="#F8F4E9"
        FontFamily="Microsoft YaHei"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="RoundButton" TargetType="Button">
            <Setter Property="Background" Value="#5C4E3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7F6E5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 文本框样式 -->
        <Style x:Key="LoginTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        
        <Style x:Key="LoginPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo/标题 -->
        <TextBlock Grid.Row="0" 
                   Text="追番手账" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="#5C4E3D"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>
        
        <TextBlock Grid.Row="1" 
                   Text="AniTechou" 
                   FontSize="14" 
                   Foreground="#A89F91"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- 账号选择/输入 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="账号" 
                       FontSize="14" 
                       Foreground="#5C4E3D"
                       Margin="0,0,0,5"/>
            <ComboBox x:Name="AccountCombo"
                      Height="35"
                      FontSize="14"
                      IsEditable="True"
                      Background="White"
                      DisplayMemberPath="UserName"/>
        </StackPanel>

        <!-- 密码输入 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <TextBlock Text="密码" 
                       FontSize="14" 
                       Foreground="#5C4E3D"
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox"
                         Style="{StaticResource LoginPasswordBox}"
                         Background="White"/>
        </StackPanel>

        <!-- 登录按钮 -->
        <Button Grid.Row="4" 
                Content="登录"
                Style="{StaticResource RoundButton}"
                HorizontalAlignment="Center"
                Click="Login_Click"/>

        <!-- 注册链接 -->
        <TextBlock Grid.Row="5" 
                   Text="还没有账号？注册新账号"
                   FontSize="12"
                   Foreground="#7F6E5A"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,0"
                   Cursor="Hand"
                   MouseLeftButtonDown="Register_Click"/>

        <!-- 错误信息显示 -->
        <TextBlock Grid.Row="6" 
                   x:Name="MessageText"
                   Text=""
                   Foreground="Red"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>