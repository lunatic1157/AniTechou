<UserControl x:Class="AniTechou.Controls.WorkCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="280" Height="160"
             Cursor="Hand">
    
    <UserControl.Resources>
        <Style TargetType="Border" x:Key="CardBorder">
            <Setter Property="Background" Value="{DynamicResource Surface1Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}"/>
            <Setter Property="Margin" Value="8"/>
        </Style>
        
        <Style TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsMouseOver}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentSoftBrush}"/>
                    <Setter Property="Effect" Value="{DynamicResource CardHoverShadow}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorder}">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 封面区域 -->
            <Border Grid.Column="0" 
                    Width="70" Height="100" 
                    Background="{DynamicResource Surface3Brush}" 
                    CornerRadius="10"
                    HorizontalAlignment="Left">
                <Grid>                          
                    <Image x:Name="CoverImage" 
                        Stretch="Uniform"
                        Source="{Binding CoverPath}"
                        Visibility="Collapsed"/>
                    <TextBlock x:Name="CoverPlaceholder" 
                            Text="📖" 
                            FontSize="40" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"/>
                </Grid>                         
            </Border>

            <!-- 作品信息 -->
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <!-- 标题 -->
                <TextBlock x:Name="TitleTextBlock" 
                        Text="{Binding Title}"
                        FontSize="14" 
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        TextWrapping="Wrap"
                        MaxHeight="40"/>

                <!-- 年份和制作 -->
                <TextBlock x:Name="InfoTextBlock" 
                        Text="{Binding Info}"
                        FontSize="11" 
                        Foreground="{DynamicResource TextMutedBrush}"
                        Margin="0,4,0,0"/>
                
                <!-- 进度条区域 -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <ProgressBar x:Name="ProgressBar"
                                 Grid.Column="0"
                                 Height="6"
                                 Background="{DynamicResource Surface3Brush}"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Value="{Binding ProgressValue}"
                                 Maximum="100"/>
                    
                    <TextBlock x:Name="ProgressTextBlock"
                            Grid.Column="1"
                            Text="{Binding ProgressText}"
                            FontSize="10"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Margin="5,0,0,0"/>
                </Grid>
                
                <!-- 评分 -->
                <TextBlock x:Name="RatingTextBlock" 
                        Text="{Binding RatingDisplay}"
                        FontSize="12"
                        Foreground="{DynamicResource AccentStrongBrush}"
                        Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
