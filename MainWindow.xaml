<Window x:Class="AniTechou.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="追番手账 · AniTechou"
        Width="1400" Height="800"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <Style x:Key="TopThemeSwatchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="2"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
            <Setter Property="ShowsPreview" Value="True"/>
        </Style>
        <Style x:Key="UserMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MaxWidth" Value="280"/>
        </Style>
        
        <Style x:Key="AIMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface3Brush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth" Value="280"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== 顶部栏 ========== -->
        <Border Grid.Row="0" 
                Margin="12,0,12,2"
                Background="{DynamicResource WindowBackgroundBrush}" 
                BorderThickness="0"
                CornerRadius="0"
                MinHeight="64"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧Logo文字 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                    <TextBlock Text="追番手账" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="AniTechou" 
                               FontSize="12" 
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0"/>
                </StackPanel>

                <!-- 中间空白 -->
                <Grid Grid.Column="1"/>

                <!-- 右侧按钮区 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,4,8,4" VerticalAlignment="Center">
                    <Button Content="📊 核查"
                            Style="{StaticResource AppIconButtonStyle}"
                            Click="RunAudit_Click"
                            ToolTip="运行数据库封面数据核查"/>
                    <Button x:Name="ThemeQuickButton"
                            Content="🎨 主题"
                            Style="{StaticResource AppIconButtonStyle}"
                            Click="ThemeQuickButton_Click"
                            ToolTip="快速切换主题色"/>
                    <Button x:Name="AIAssistantButton"
                            Content="🤖 AI助手"
                            Style="{StaticResource AppIconButtonStyle}"
                            Click="ToggleAIPanel_Click"/>
                    <Button Content="👤 个人主页"
                            Style="{StaticResource AppIconButtonStyle}"
                            Click="Profile_Click"/>
                    <Button Content="⚙️ 设置"
                            Style="{StaticResource AppIconButtonStyle}"
                            Click="Settings_Click"/>
                    <Button Content="&#xE921;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource AppWindowControlButtonStyle}"
                            ToolTip="最小化"
                            Click="MinimizeWindow_Click"/>
                    <Button x:Name="MaximizeRestoreButton"
                            Content="&#xE922;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource AppWindowControlButtonStyle}"
                            ToolTip="最大化"
                            Click="MaximizeWindow_Click"/>
                    <Button Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource AppWindowControlButtonStyle}"
                            ToolTip="关闭"
                            Click="CloseWindow_Click"/>
                </StackPanel>

                <Popup x:Name="TopThemePopup"
                       PlacementTarget="{Binding ElementName=ThemeQuickButton}"
                       Placement="Bottom"
                       VerticalOffset="10"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource Surface1Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Effect="{DynamicResource PopupShadow}">
                        <StackPanel>
                            <TextBlock x:Name="TopThemeHintText"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,10"/>
                            <WrapPanel x:Name="TopThemePalettePanel" MaxWidth="240"/>
                            <TextBlock Text="明暗模式"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,6,0,8"/>
                            <WrapPanel>
                                <ToggleButton x:Name="TopLightModeButton"
                                              Content="Light"
                                              Width="82"
                                              Height="34"
                                              Margin="0,0,8,0"
                                              Style="{StaticResource AppToggleButtonStyle}"
                                              Click="TopThemeModeButton_Click"
                                              Tag="Light"/>
                                <ToggleButton x:Name="TopDarkModeButton"
                                              Content="Dark"
                                              Width="82"
                                              Height="34"
                                              Style="{StaticResource AppToggleButtonStyle}"
                                              Click="TopThemeModeButton_Click"
                                              Tag="Dark"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <!-- ========== 主内容区域 ========== -->
        <Grid Grid.Row="1" x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="AIPanelColumn" Width="320" MaxWidth="450"/>
            </Grid.ColumnDefinitions>

            <!-- ========== 左侧边栏 ========== -->
            <ScrollViewer Grid.Column="0" 
                          VerticalScrollBarVisibility="Auto"
                          Margin="12,0,10,12"
                          Background="{DynamicResource Surface1Brush}"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="SidebarPanel" Margin="12">

                    <!-- 快速笔记按钮 -->
                    <Button x:Name="QuickNoteButton"
                            Content="📝 快速笔记"
                            Style="{StaticResource AppSidebarButtonStyle}"
                            FontWeight="Bold"
                            Click="QuickNote_Click"/>

                    <!-- 作品库 -->
                    <TextBlock Text="📁 作品库" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,14,0,10"/>
                    <Button Content="📋 全部作品" Style="{StaticResource AppSidebarButtonStyle}" Tag="all" Click="SidebarMenu_Click"/>
                    <Button Content="🎬 动画" Style="{StaticResource AppSidebarButtonStyle}" Tag="anime" Click="SidebarMenu_Click"/>
                    <Button Content="📚 漫画" Style="{StaticResource AppSidebarButtonStyle}" Tag="manga" Click="SidebarMenu_Click"/>
                    <Button Content="📖 轻小说" Style="{StaticResource AppSidebarButtonStyle}" Tag="lightnovel" Click="SidebarMenu_Click"/>
                    <Button Content="🎮 游戏" Style="{StaticResource AppSidebarButtonStyle}" Tag="game" Click="SidebarMenu_Click"/>
                    <Button Content="👀 想看" Style="{StaticResource AppSidebarButtonStyle}" Tag="wish" Click="SidebarMenu_Click"/>
                    <Button Content="▶️ 在看" Style="{StaticResource AppSidebarButtonStyle}" Tag="doing" Click="SidebarMenu_Click"/>
                    <Button Content="✅ 看过" Style="{StaticResource AppSidebarButtonStyle}" Tag="done" Click="SidebarMenu_Click"/>

                    <!-- 笔记中心 -->
                    <TextBlock Text="📝 笔记中心" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,14,0,10"/>
                    <Button Content="📌 全部笔记" Style="{StaticResource AppSidebarButtonStyle}" Tag="notes" Click="SidebarMenu_Click"/>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"/>

            <!-- ========== 中间内容区 ========== -->
            <Grid Grid.Column="2" Margin="0,0,10,12" Background="{DynamicResource Surface1Brush}">
                <TextBlock x:Name="ContentPlaceholder"
                           Text="👈 从左侧选择要查看的内容"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="16"/>
                <ContentControl x:Name="MainContentArea" Visibility="Collapsed"/>
            </Grid>

            <GridSplitter x:Name="AIPanelSplitter" Grid.Column="3" Width="4" ResizeDirection="Columns"/>

            <!-- ========== 右侧AI对话面板 ========== -->
            <Grid x:Name="AIPanel" Grid.Column="4" Margin="0,0,12,12" Background="{DynamicResource Surface1Brush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- AI面板头部 -->
                <Border Grid.Row="0" 
                        Background="{DynamicResource Surface2Brush}" 
                        Padding="14,12">
                    <TextBlock Text="🤖 AI助手" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>

                <!-- 对话记录区域 -->
                <ScrollViewer x:Name="ChatScrollViewer" 
                              Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              Margin="10,10,10,0">
                    <StackPanel x:Name="ChatMessagesPanel">
                        <Border Style="{StaticResource AIMessageStyle}">
                            <TextBlock Text="👋 你好！我是你的AI助手。我可以帮你：&#x0a;• 搜索动漫、漫画、轻小说、游戏信息&#x0a;• 推荐相似作品&#x0a;• 帮你批量添加作品到列表&#x0a;• 回答关于ACGN的问题" 
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 输入区域（底部） -->
                <Border Grid.Row="2"
                        Background="{DynamicResource Surface2Brush}"
                        Padding="10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AIChatInputBox"
                                     Grid.Column="0"
                                     Height="42"
                                     MinHeight="42"
                                     MaxHeight="180"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Disabled"
                                     FontSize="13"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     ToolTip="输入你想问的问题..."
                                     VerticalAlignment="Center"
                                     TextChanged="AIChatInputBox_TextChanged"
                                     KeyDown="AIChatInputBox_KeyDown"/>

                            <Button Grid.Column="1"
                                    Content="发送"
                                    Width="60"
                                    Height="32"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource AppPrimaryButtonStyle}"
                                    Click="SendAIChat_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
