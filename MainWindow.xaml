<Window x:Class="AniTechou.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="追番手账 · AniTechou"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#F8F4E9"
        FontFamily="Microsoft YaHei">
    
    <Window.Resources>
        <!-- 分割条样式 -->
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="#E0D5C0"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="3"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
        </Style>
        
        <!-- 侧边栏按钮样式 -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5C4E3D"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0D5C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 分组标题样式 -->
        <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5C4E3D"/>
            <Setter Property="Margin" Value="10,10,0,5"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 左侧边栏 ========== -->
        <Grid Grid.Column="0" Background="#F0E9DD">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 快速笔记按钮 -->
            <Button Grid.Row="0" 
                    Content="📝 随手记 (Ctrl+N)"
                    Style="{StaticResource SidebarButtonStyle}"
                    Background="#D4C9B8"
                    FontWeight="Bold"
                    Margin="5"
                    Click="QuickNote_Click"/>

            <!-- 作品库 -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="📁 作品库" Style="{StaticResource GroupHeaderStyle}"/>
                <Button Content="📋 全部作品" Style="{StaticResource SidebarButtonStyle}" Tag="all" Click="SidebarMenu_Click"/>
                <Button Content="🎬 动画" Style="{StaticResource SidebarButtonStyle}" Tag="anime" Click="SidebarMenu_Click"/>
                <Button Content="📚 漫画" Style="{StaticResource SidebarButtonStyle}" Tag="manga" Click="SidebarMenu_Click"/>
                <Button Content="📖 轻小说" Style="{StaticResource SidebarButtonStyle}" Tag="lightnovel" Click="SidebarMenu_Click"/>
                <Button Content="🎮 游戏" Style="{StaticResource SidebarButtonStyle}" Tag="game" Click="SidebarMenu_Click"/>
                <Button Content="👀 想看" Style="{StaticResource SidebarButtonStyle}" Tag="wish" Click="SidebarMenu_Click"/>
                <Button Content="▶️ 在看" Style="{StaticResource SidebarButtonStyle}" Tag="doing" Click="SidebarMenu_Click"/>
                <Button Content="✅ 看过" Style="{StaticResource SidebarButtonStyle}" Tag="done" Click="SidebarMenu_Click"/>
            </StackPanel>

            <!-- 笔记中心 -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="📝 笔记中心" Style="{StaticResource GroupHeaderStyle}"/>
                <Button Content="📌 全部笔记" Style="{StaticResource SidebarButtonStyle}" Tag="notes" Click="SidebarMenu_Click"/>
                <Button Content="🏷️ 按标签" Style="{StaticResource SidebarButtonStyle}" Tag="tags" Click="SidebarMenu_Click"/>
            </StackPanel>

            <!-- 最近浏览 -->
            <StackPanel Grid.Row="3">
                <TextBlock Text="🕒 最近浏览" Style="{StaticResource GroupHeaderStyle}"/>
                <ListBox x:Name="RecentList" 
                         Background="Transparent"
                         BorderThickness="0"
                         MaxHeight="120"
                         DisplayMemberPath="Title"
                         SelectionChanged="RecentList_SelectionChanged"/>
            </StackPanel>

            <!-- 个人主页入口 -->
            <Button Grid.Row="5" 
                    Content="👤 个人主页"
                    Style="{StaticResource SidebarButtonStyle}"
                    Margin="5"
                    Click="Profile_Click"/>
        </Grid>

        <!-- 第一个分割条 -->
        <GridSplitter Grid.Column="1"/>

        <!-- ========== 中间内容区 ========== -->
        <Grid Grid.Column="2" Background="White">
            <TextBlock x:Name="ContentPlaceholder"
                       Text="👈 从左侧选择要查看的内容"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#A89F91"
                       FontSize="16"/>
            
            <ContentControl x:Name="MainContentArea"/>
        </Grid>

        <!-- 第二个分割条 -->
        <GridSplitter Grid.Column="3"/>

        <!-- ========== 右侧AI面板 ========== -->
        <Grid Grid.Column="4" Background="#F0E9DD">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 折叠按钮 -->
            <Button Grid.Row="0" 
                    Content="▶ 收起"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="5"
                    Cursor="Hand"
                    Click="ToggleAIPanel_Click"/>

            <!-- AI搜索框 -->
            <StackPanel Grid.Row="1" Margin="10">
                <TextBox x:Name="AISearchBox"
                         Height="35"
                         Padding="5"
                         TextWrapping="Wrap"
                         FontSize="14"
                         Background="White"
                         ToolTip="输入你想搜索的内容..."/>
                <Button Content="AI搜索"
                        Height="30"
                        Margin="0,5,0,0"
                        Background="#5C4E3D"
                        Foreground="White"
                        Click="AISearch_Click"/>
            </StackPanel>

            <!-- 结果区域 -->
            <ListBox Grid.Row="2" 
                     x:Name="AIResultList"
                     Margin="10,0,10,10"
                     Background="White"
                     BorderThickness="1"
                     BorderBrush="#E0D5C0"
                     DisplayMemberPath="DisplayText"/>
        </Grid>
    </Grid>
</Window>