<Window x:Class="AniTechou.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="追番手账 · AniTechou"
        Width="1400" Height="800"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F8F4E9"
        FontFamily="Microsoft YaHei"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <!-- 分割条样式 -->
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="#E0D5C0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="ResizeBehavior" Value="PreviousAndNext"/>
            <Setter Property="ShowsPreview" Value="True"/>
        </Style>
        
        <!-- 侧边栏按钮样式 -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5C4E3D"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0D5C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 分组标题样式 -->
        <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5C4E3D"/>
            <Setter Property="Margin" Value="10,10,0,5"/>
        </Style>
        
        <!-- 顶部栏按钮样式 -->
        <Style x:Key="TopBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0D5C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 窗口控制按钮样式 -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0D5C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- AI对话消息样式 -->
        <Style x:Key="UserMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8F0FE"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MaxWidth" Value="280"/>
        </Style>
        
        <Style x:Key="AIMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="#F0E9DD"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MaxWidth" Value="280"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== 顶部栏 ========== -->
        <Border Grid.Row="0" 
                Background="#F0E9DD" 
                BorderBrush="#E0D5C0" 
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧Logo文字 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0,0,0">
                    <TextBlock Text="追番手账" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="#5C4E3D"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="AniTechou" 
                               FontSize="12" 
                               Foreground="#A89F91"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0"/>
                </StackPanel>

                <!-- 中间空白 -->
                <Grid Grid.Column="1"/>

                <!-- 右侧按钮区 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="AIAssistantButton"
                            Content="🤖 AI助手"
                            Style="{StaticResource TopBarButton}"
                            Click="ToggleAIPanel_Click"/>
                    <Button Content="👤 个人主页"
                            Style="{StaticResource TopBarButton}"
                            Click="Profile_Click"/>
                    <Button Content="⚙️ 设置"
                            Style="{StaticResource TopBarButton}"
                            Click="Settings_Click"/>
                    <Button Content="─" 
                            Style="{StaticResource WindowControlButton}"
                            Click="MinimizeWindow_Click"/>
                    <Button Content="□" 
                            Style="{StaticResource WindowControlButton}"
                            Click="MaximizeWindow_Click"/>
                    <Button Content="✕" 
                            Style="{StaticResource WindowControlButton}"
                            Background="#E06C6C"
                            Foreground="White"
                            Click="CloseWindow_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== 主内容区域 ========== -->
        <Grid Grid.Row="1" x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="AIPanelColumn" Width="320" MaxWidth="450"/>
            </Grid.ColumnDefinitions>

            <!-- ========== 左侧边栏 ========== -->
            <ScrollViewer Grid.Column="0" 
                          VerticalScrollBarVisibility="Auto"
                          Background="#F0E9DD"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- 快速笔记按钮 -->
                    <Button Content="📝 随手记 (Ctrl+N)"
                            Style="{StaticResource SidebarButtonStyle}"
                            Background="#D4C9B8"
                            FontWeight="Bold"
                            Margin="5"
                            Click="QuickNote_Click"/>

                    <!-- 作品库 -->
                    <TextBlock Text="📁 作品库" Style="{StaticResource GroupHeaderStyle}"/>
                    <Button Content="📋 全部作品" Style="{StaticResource SidebarButtonStyle}" Tag="all" Click="SidebarMenu_Click"/>
                    <Button Content="🎬 动画" Style="{StaticResource SidebarButtonStyle}" Tag="anime" Click="SidebarMenu_Click"/>
                    <Button Content="📚 漫画" Style="{StaticResource SidebarButtonStyle}" Tag="manga" Click="SidebarMenu_Click"/>
                    <Button Content="📖 轻小说" Style="{StaticResource SidebarButtonStyle}" Tag="lightnovel" Click="SidebarMenu_Click"/>
                    <Button Content="🎮 游戏" Style="{StaticResource SidebarButtonStyle}" Tag="game" Click="SidebarMenu_Click"/>
                    <Button Content="👀 想看" Style="{StaticResource SidebarButtonStyle}" Tag="wish" Click="SidebarMenu_Click"/>
                    <Button Content="▶️ 在看" Style="{StaticResource SidebarButtonStyle}" Tag="doing" Click="SidebarMenu_Click"/>
                    <Button Content="✅ 看过" Style="{StaticResource SidebarButtonStyle}" Tag="done" Click="SidebarMenu_Click"/>

                    <!-- 笔记中心 -->
                    <TextBlock Text="📝 笔记中心" Style="{StaticResource GroupHeaderStyle}"/>
                    <Button Content="📌 全部笔记" Style="{StaticResource SidebarButtonStyle}" Tag="notes" Click="SidebarMenu_Click"/>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"/>

            <!-- ========== 中间内容区 ========== -->
            <Grid Grid.Column="2" Background="White">
                <TextBlock x:Name="ContentPlaceholder"
                           Text="👈 从左侧选择要查看的内容"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#A89F91"
                           FontSize="16"/>
                <ContentControl x:Name="MainContentArea" Visibility="Collapsed"/>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" ResizeDirection="Columns"/>

            <!-- ========== 右侧AI对话面板 ========== -->
            <Grid x:Name="AIPanel" Grid.Column="4" Background="#F8F4E9">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- AI面板头部 -->
                <Border Grid.Row="0" 
                        Background="#F0E9DD" 
                        BorderBrush="#E0D5C0" 
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <TextBlock Text="🤖 AI助手" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="#5C4E3D"/>
                </Border>

                <!-- 对话记录区域 -->
                <ScrollViewer x:Name="ChatScrollViewer" 
                              Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              Margin="10,10,10,0">
                    <StackPanel x:Name="ChatMessagesPanel">
                        <Border Style="{StaticResource AIMessageStyle}">
                            <TextBlock Text="👋 你好！我是你的AI助手。我可以帮你：&#x0a;• 搜索动漫、漫画、轻小说、游戏信息&#x0a;• 推荐相似作品&#x0a;• 帮你批量添加作品到列表&#x0a;• 回答关于ACGN的问题" 
                                       TextWrapping="Wrap"
                                       FontSize="12"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 输入区域（底部） -->
                <Border Grid.Row="2" 
                        Background="#F0E9DD" 
                        BorderBrush="#E0D5C0" 
                        BorderThickness="0,1,0,0"
                        Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="AIChatInputBox"
                                 Grid.Column="0"
                                 Height="35"
                                 Padding="8,5"
                                 TextWrapping="Wrap"
                                 FontSize="13"
                                 Background="White"
                                 ToolTip="输入你想问的问题..."
                                 VerticalAlignment="Center"
                                 KeyDown="AIChatInputBox_KeyDown"/>
                        
                        <Button Grid.Column="1"
                                Content="发送"
                                Width="60"
                                Height="32"
                                Margin="8,0,0,0"
                                Background="#5C4E3D"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="SendAIChat_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>