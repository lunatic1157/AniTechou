<UserControl x:Class="AniTechou.Views.AddWorkForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="添加作品" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="20">
            <StackPanel>
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="标题 *" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBox x:Name="TitleBox" Grid.Column="1" Height="40" Style="{StaticResource AppTextBoxStyle}"/>
            </Grid>
            
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="原名" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBox x:Name="OriginalTitleBox" Grid.Column="1" Height="40" Style="{StaticResource AppTextBoxStyle}"/>
            </Grid>
            
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="类型 *" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="TypeBox" Grid.Column="1" Height="40" Style="{StaticResource AppComboBoxStyle}" SelectionChanged="TypeBox_SelectionChanged"/>
            </Grid>
            
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="年份/季度" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="YearBox" Width="84" Height="40" ToolTip="例如: 2024" Style="{StaticResource AppTextBoxStyle}"/>
                    <ComboBox x:Name="SeasonBox" Width="92" Height="40" Margin="8,0,0,0" Style="{StaticResource AppComboBoxStyle}"/>
                </StackPanel>
            </Grid>
            
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="原作类型" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="SourceTypeBox" Grid.Column="1" Height="40" Style="{StaticResource AppComboBoxStyle}"/>
            </Grid>

            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CompanyLabel" Grid.Column="0" Text="制作公司" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CompanyBox" Grid.Column="0" Height="40" ToolTip="制作公司/出版社/作者" Style="{StaticResource AppTextBoxStyle}"/>
                    <TextBlock Grid.Column="1" Text="原作" Foreground="{DynamicResource TextPrimaryBrush}" Margin="10,0,8,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="OriginalWorkBox" Grid.Column="2" Height="40" ToolTip="原作作者（如小说作者）" Style="{StaticResource AppTextBoxStyle}"/>
                </Grid>
            </Grid>
            
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="集数/卷数" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBox x:Name="EpisodesBox" Grid.Column="1" Height="40" Style="{StaticResource AppTextBoxStyle}"/>
            </Grid>
            
            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,18,0,14"/>
            
            <TextBlock Text="个人状态" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
            
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="状态" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="StatusBox" Grid.Column="1" Height="40" Style="{StaticResource AppComboBoxStyle}"/>
            </Grid>
            
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="进度" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBox x:Name="ProgressBox" Grid.Column="1" Height="40" Style="{StaticResource AppTextBoxStyle}"/>
            </Grid>
            
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="评分" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="RatingBox" Grid.Column="1" Height="40" Width="180" HorizontalAlignment="Left" Style="{StaticResource AppComboBoxStyle}"/>
            </Grid>
            
            <Border Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,18,0,14"/>
            
            <TextBlock Text="封面" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
            
            <Border Background="{DynamicResource Surface2Brush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource CardCornerRadius}" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="84" Height="108" Background="{DynamicResource Surface3Brush}" CornerRadius="8">
                        <Grid>
                            <Image x:Name="CoverPreview" Stretch="Uniform"/>
                            <TextBlock x:Name="CoverPlaceholder" Text="无封面" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="点击按钮选择图片" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Button Content="选择封面图片" 
                                Width="116" Height="36"
                                Margin="0,5,0,0"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="SelectCover_Click"/>
                        <TextBlock x:Name="CoverPathText" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <TextBlock Text="简介" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,15,0,10"/>
            <TextBox x:Name="SynopsisBox" Height="120" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Style="{StaticResource AppTextBoxStyle}"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25">
                <Button Content="保存" Width="100" Height="38" Style="{StaticResource AppPrimaryButtonStyle}" Click="Save_Click" Margin="0,0,15,0"/>
                <Button Content="取消" Width="100" Height="38" Style="{StaticResource AppSecondaryButtonStyle}" Click="Cancel_Click"/>
            </StackPanel>
            </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
