<UserControl x:Class="AniTechou.Views.AddWorkForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="添加作品" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#5C4E3D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>
            
            <!-- 标题 -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="标题 *" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <TextBox x:Name="TitleBox" Grid.Column="1" Height="30"/>
            </Grid>
            
            <!-- 原名 -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="原名" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <TextBox x:Name="OriginalTitleBox" Grid.Column="1" Height="30"/>
            </Grid>
            
            <!-- 类型 -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="类型 *" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <ComboBox x:Name="TypeBox" Grid.Column="1" Height="30" SelectedIndex="0">
                    <ComboBoxItem Content="动画"/>
                    <ComboBoxItem Content="漫画"/>
                    <ComboBoxItem Content="轻小说"/>
                    <ComboBoxItem Content="游戏"/>
                </ComboBox>
            </Grid>
            
            <!-- 年份和季度 -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="年份/季度" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="YearBox" Width="60" Height="30"/>
                    <ComboBox x:Name="SeasonBox" Width="50" Height="30" Margin="5,0,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="春"/>
                        <ComboBoxItem Content="夏"/>
                        <ComboBoxItem Content="秋"/>
                        <ComboBoxItem Content="冬"/>
                        <ComboBoxItem Content=""/>
                    </ComboBox>
                </StackPanel>
            </Grid>
            
            <!-- 原作类型 -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="原作类型" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <ComboBox x:Name="SourceTypeBox" Grid.Column="1" Height="30" SelectedIndex="0">
                    <ComboBoxItem Content="原创"/>
                    <ComboBoxItem Content="漫改"/>
                    <ComboBoxItem Content="小说改"/>
                    <ComboBoxItem Content="游戏改"/>
                    <ComboBoxItem Content="其他"/>
                </ComboBox>
            </Grid>

            <!-- 制作 -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="制作" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <TextBox x:Name="CompanyBox" Grid.Column="1" Height="30"/>
            </Grid>
            
            <!-- 集数/卷数 -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="集数/卷数" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <TextBox x:Name="EpisodesBox" Grid.Column="1" Height="30"/>
            </Grid>
            
            <Border Height="1" Background="#E0D5C0" Margin="0,15,0,10"/>
            
            <TextBlock Text="个人状态" FontSize="14" FontWeight="Bold" Foreground="#5C4E3D" Margin="0,0,0,10"/>
            
            <!-- 状态 -->
            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="状态" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <ComboBox x:Name="StatusBox" Grid.Column="1" Height="30" SelectedIndex="0">
                    <ComboBoxItem Content="想看"/>
                    <ComboBoxItem Content="在看"/>
                    <ComboBoxItem Content="看过"/>
                </ComboBox>
            </Grid>
            
            <!-- 进度 -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="进度" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <TextBox x:Name="ProgressBox" Grid.Column="1" Height="30"/>
            </Grid>
            
            <!-- 评分 -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="评分" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                <ComboBox x:Name="RatingBox" Grid.Column="1" Height="30" Width="120" HorizontalAlignment="Left" SelectedIndex="0">
                    <ComboBoxItem Content="未评分"/>
                    <ComboBoxItem Content="★☆☆☆☆ (1-2分)"/>
                    <ComboBoxItem Content="★★☆☆☆ (3-4分)"/>
                    <ComboBoxItem Content="★★★☆☆ (5-6分)"/>
                    <ComboBoxItem Content="★★★★☆ (7-8分)"/>
                    <ComboBoxItem Content="★★★★★ (9-10分)"/>
                </ComboBox>
            </Grid>
            
            <Border Height="1" Background="#E0D5C0" Margin="0,15,0,10"/>
            
            <TextBlock Text="封面" FontSize="14" FontWeight="Bold" Foreground="#5C4E3D" Margin="0,0,0,10"/>
            
            <!-- 封面区域 -->
            <Border Background="#F0E9DD" BorderBrush="#E0D5C0" BorderThickness="1" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 封面预览 -->
                    <Border Grid.Column="0" Width="80" Height="100" Background="#E0D5C0" CornerRadius="4">
                        <Grid>
                            <Image x:Name="CoverPreview" Stretch="Uniform"/>
                            <TextBlock x:Name="CoverPlaceholder" Text="无封面" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#7F6E5A"/>
                        </Grid>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="点击按钮选择图片" FontSize="11" Foreground="#7F6E5A"/>
                        <Button Content="选择封面图片" 
                                Width="100" Height="30"
                                Margin="0,5,0,0"
                                Background="#5C4E3D" 
                                Foreground="White"
                                Click="SelectCover_Click"/>
                        <TextBlock x:Name="CoverPathText" FontSize="10" Foreground="#A89F91" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- 简介 -->
            <TextBlock Text="简介" FontSize="14" FontWeight="Bold" Foreground="#5C4E3D" Margin="0,15,0,10"/>
            <TextBox x:Name="SynopsisBox" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            
            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25">
                <Button Content="保存" Width="100" Height="35" Background="#5C4E3D" Foreground="White" Click="Save_Click" Margin="0,0,15,0"/>
                <Button Content="取消" Width="100" Height="35" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>