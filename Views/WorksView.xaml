<UserControl x:Class="AniTechou.Views.WorksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AniTechou.Controls"
             Background="{DynamicResource Surface1Brush}">

    <UserControl.Resources>
        <!-- 搜索框样式 -->
        <Style x:Key="SearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
        </Style>
        
        <Style x:Key="FilterButton" TargetType="Button" BasedOn="{StaticResource AppFilterChipButtonStyle}">
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>

        <!-- 卡片面板样式（网格布局） -->
        <ItemsPanelTemplate x:Key="GridPanel">
            <WrapPanel Orientation="Horizontal"
                       Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth}"
                       ItemWidth="290"/>
        </ItemsPanelTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 筛选栏 -->
        <Border Grid.Row="0"
                Background="{DynamicResource Surface1Brush}"
                Padding="18,16">
            <StackPanel>
                <!-- 第一行：类型/状态切换 -->
                <WrapPanel Margin="0,0,0,10">
                    <Button Content="全部作品"
                            Tag="all"
                            Style="{StaticResource FilterButton}"
                            Click="TypeFilter_Click"
                            x:Name="AllButton"/>
                    <Button Content="动画"
                            Tag="Anime"
                            Style="{StaticResource FilterButton}"
                            Click="TypeFilter_Click"
                            x:Name="AnimeButton"/>
                    <Button Content="漫画"
                            Tag="Manga"
                            Style="{StaticResource FilterButton}"
                            Click="TypeFilter_Click"
                            x:Name="MangaButton"/>
                    <Button Content="轻小说"
                            Tag="LightNovel"
                            Style="{StaticResource FilterButton}"
                            Click="TypeFilter_Click"
                            x:Name="LightNovelButton"/>
                    <Button Content="游戏"
                            Tag="Game"
                            Style="{StaticResource FilterButton}"
                            Click="TypeFilter_Click"
                            x:Name="GameButton"/>
                </WrapPanel>

                <!-- 第二行：状态筛选 -->
                <WrapPanel Margin="0,0,0,10">
                    <Button Content="全部状态"
                            Tag="all"
                            Style="{StaticResource FilterButton}"
                            Click="StatusFilter_Click"
                            x:Name="AllStatusButton"/>
                    <Button Content="想看"
                            Tag="wish"
                            Style="{StaticResource FilterButton}"
                            Click="StatusFilter_Click"
                            x:Name="WishButton"/>
                    <Button Content="在看"
                            Tag="doing"
                            Style="{StaticResource FilterButton}"
                            Click="StatusFilter_Click"
                            x:Name="DoingButton"/>
                    <Button Content="看过"
                            Tag="done"
                            Style="{StaticResource FilterButton}"
                            Click="StatusFilter_Click"
                            x:Name="DoneButton"/>
                </WrapPanel>

                <!-- 第三行：年份/季度/原作类型/制作 -->
                <WrapPanel Margin="0,0,0,10">
                    <ComboBox x:Name="YearFilter"
                              Width="118"
                              Height="36"
                              Margin="0,0,10,5"
                              Style="{StaticResource AppComboBoxStyle}"
                              SelectionChanged="YearFilter_Changed"/>

                    <ComboBox x:Name="SeasonFilter"
                              Width="108"
                              Height="36"
                              Margin="0,0,10,5"
                              Style="{StaticResource AppComboBoxStyle}"
                              SelectionChanged="SeasonFilter_Changed"/>

                    <ComboBox x:Name="SourceTypeFilter"
                              Width="136"
                              Height="36"
                              Margin="0,0,10,5"
                              Style="{StaticResource AppComboBoxStyle}"
                              SelectionChanged="SourceTypeFilter_Changed"/>

                    <ComboBox x:Name="StudioFilter"
                              Width="168"
                              Height="36"
                              Margin="0,0,10,5"
                              Style="{StaticResource AppComboBoxStyle}"
                              SelectionChanged="StudioFilter_Changed"/>

                    <ComboBox x:Name="RatingFilter"
                              Width="156"
                              Height="36"
                              Margin="0,0,10,5"
                              Style="{StaticResource AppComboBoxStyle}"
                              SelectionChanged="RatingFilter_Changed"/>

                    <!-- 标签搜索框 -->
                    <TextBox x:Name="TagSearchBox"
                             Width="188"
                             Height="42"
                             Margin="0,0,10,5"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             ToolTip="搜索标签..."
                             TextChanged="TagSearch_TextChanged"
                             Style="{StaticResource SearchTextBoxStyle}"/>
                </WrapPanel>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="标签筛选"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="ExpandTagsButton"
                            DockPanel.Dock="Right"
                            Content="展开更多 ▼"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            Cursor="Hand"
                            Margin="10,0,0,0"
                            Click="ExpandTags_Click"
                            Visibility="Collapsed"/>
                </DockPanel>

                <!-- 第四行：标签筛选 -->
                <StackPanel Margin="0,0,0,10">
                    <Border Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource InputCornerRadius}">
                        <ScrollViewer x:Name="TagsScrollViewer"
                                      MaxHeight="104"
                                      VerticalScrollBarVisibility="Disabled"
                                      Padding="10">
                            <ItemsControl x:Name="TagsFilterItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- 第五行：视图切换和添加按钮 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 清除筛选按钮 -->
                    <Button Grid.Column="0"
                            Content="清除筛选"
                            Width="92" Height="34"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Click="ClearFilters_Click"/>

                    <!-- 标题和计数 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   Text="全部作品"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="CountText"
                                   Text="(0)"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Bottom"
                                   Margin="8,0,0,5"/>
                    </StackPanel>

                    <!-- 右侧按钮组 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="➕ 添加作品"
                                Width="100" Height="34"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="AddWork_Click"
                                Margin="0,0,5,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 作品列表区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="WorksItemsControl"
                          Margin="10"
                          ItemsPanel="{StaticResource GridPanel}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:WorkCard
                            WorkId="{Binding Id}"
                            Title="{Binding Title}"
                            Info="{Binding Info}"
                            CoverPath="{Binding CoverPath}"
                            ProgressValue="{Binding ProgressValue}"
                            ProgressText="{Binding ProgressText}"
                            RatingDisplay="{Binding RatingDisplay}"
                            Click="OnWorkCardClick"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 加载中提示 -->
        <TextBlock x:Name="LoadingText"
                   Grid.Row="1"
                   Text="加载中..."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="14"
                   Visibility="Collapsed"/>

        <!-- 空状态提示 -->
        <TextBlock x:Name="EmptyText"
                   Grid.Row="1"
                   Text="暂无作品，去添加吧～"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="14"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>
