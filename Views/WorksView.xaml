<UserControl x:Class="AniTechou.Views.WorksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AniTechou.Controls"
             Background="White">
    
    <UserControl.Resources>
        <!-- 视图切换按钮样式 -->
        <Style x:Key="ViewToggleButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0D5C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 卡片面板样式（网格布局） -->
        <ItemsPanelTemplate x:Key="GridPanel">
            <WrapPanel Orientation="Horizontal" 
                       Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth}"
                       ItemWidth="290"/>
        </ItemsPanelTemplate>
        
        <!-- 列表面板样式（垂直布局） -->
        <ItemsPanelTemplate x:Key="ListPanel">
            <StackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="#E0D5C0" 
                BorderThickness="0,0,0,1"
                Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标题和计数 -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="TitleText" 
                               Text="全部作品" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#5C4E3D"/>
                    <TextBlock x:Name="CountText" 
                               Text="(0)" 
                               FontSize="14" 
                               Foreground="#A89F91" 
                               VerticalAlignment="Bottom" 
                               Margin="8,0,0,5"/>
                </StackPanel>
                
                <!-- 右侧按钮区域 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ 添加作品"
                            Width="100"
                            Height="30"
                            Background="#5C4E3D"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="AddWork_Click"/>
                    <Button x:Name="GridButton" 
                            Content="▦" 
                            Width="30" 
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="SetGridView_Click"
                            Margin="5,0,0,0"/>
                    <Button x:Name="ListButton" 
                            Content="☰" 
                            Width="30" 
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="SetListView_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 作品列表区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="WorksItemsControl"
                          Margin="10"
                          ItemsPanel="{StaticResource GridPanel}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:WorkCard 
                            WorkId="{Binding Id}"
                            Title="{Binding Title}"
                            Info="{Binding Info}"
                            ProgressValue="{Binding ProgressValue}"
                            ProgressText="{Binding ProgressText}"
                            RatingDisplay="{Binding RatingDisplay}"
                            Click="OnWorkCardClick"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 加载中提示 -->
        <TextBlock x:Name="LoadingText"
                   Grid.Row="1"
                   Text="加载中..."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#A89F91"
                   FontSize="14"
                   Visibility="Collapsed"/>
        
        <!-- 空状态提示 -->
        <TextBlock x:Name="EmptyText"
                   Grid.Row="1"
                   Text="暂无作品，去添加吧～"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#A89F91"
                   FontSize="14"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>