<UserControl x:Class="AniTechou.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource AppHeadingTextStyle}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="设置"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🤖 AI 服务设置" Style="{StaticResource SectionTitleStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AI 平台" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="PlatformBox"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Height="40"
                                  Margin="0,0,0,12"
                                  Style="{StaticResource AppComboBoxStyle}"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="Platform_SelectionChanged"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key" Style="{StaticResource FieldLabelStyle}"/>
                        <PasswordBox x:Name="ApiKeyBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Height="40"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource AppPasswordBoxStyle}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="API 地址" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Height="40"
                                Margin="0,0,0,12"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource InputCornerRadius}"
                                Padding="12,10">
                            <TextBlock x:Name="ApiUrlBox"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="模型" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Grid.Row="3"
                                Grid.Column="1"
                                Height="40"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource InputCornerRadius}"
                                Padding="12,10">
                            <TextBlock x:Name="ModelBox"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </Grid>

                    <WrapPanel Margin="0,18,0,0">
                        <Button Content="测试连接"
                                Width="96"
                                Height="36"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="TestConnection_Click"/>
                        <Button Content="编辑 AI 提示词"
                                Width="132"
                                Height="36"
                                Margin="0,0,12,0"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="EditPrompt_Click"
                                ToolTip="自定义 AI 助手的系统提示词，调整其行为"/>
                        <TextBlock x:Name="TestStatusText"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚙️ 通用设置" Style="{StaticResource SectionTitleStyle}"/>
                    <CheckBox x:Name="AutoLoginBox"
                              Content="启动时自动登录"
                              Margin="0,0,0,18"
                              Style="{StaticResource AppCheckBoxStyle}"/>
                    <Button Content="退出登录"
                            Width="110"
                            Height="36"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Click="Logout_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="💾 数据设置" Style="{StaticResource SectionTitleStyle}"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Button Content="导入数据"
                                Width="120"
                                Height="36"
                                Margin="0,0,12,0"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="ImportData_Click"/>
                        <Button Content="导出所有数据"
                                Width="132"
                                Height="36"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="ExportData_Click"/>
                    </WrapPanel>
                    <TextBlock Text="数据保存位置"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock x:Name="DataPathText"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,10"/>
                    <Button Content="打开数据文件夹"
                            Width="126"
                            Height="34"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AppGhostButtonStyle}"
                            Click="OpenDataFolder_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24">
                <StackPanel>
                    <TextBlock Text="ℹ️ 关于" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="追番手账 AniTechou"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="版本 1.0"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,6,0,0"/>
                    <TextBlock Text="个人 ACGN 收藏工具"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="保存设置"
                    Width="120"
                    Height="40"
                    Style="{StaticResource AppPrimaryButtonStyle}"
                    Click="Save_Click"
                    HorizontalAlignment="Center"
                    Margin="0,30,0,20"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
