<UserControl x:Class="AniTechou.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource AppHeadingTextStyle}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="设置"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🤖 AI 服务设置" Style="{StaticResource SectionTitleStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AI 平台" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="PlatformBox"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  Height="40"
                                  Margin="0,0,0,12"
                                  Style="{StaticResource AppComboBoxStyle}"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="Platform_SelectionChanged"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key" Style="{StaticResource FieldLabelStyle}"/>
                        <PasswordBox x:Name="ApiKeyBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Height="40"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource AppPasswordBoxStyle}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="API 地址" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="ApiUrlBox"
                                 Grid.Row="2"
                                 Grid.Column="1"
                                 Height="40"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 TextChanged="ApiUrlOrModel_TextChanged"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="模型" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="ModelBox"
                                 Grid.Row="3"
                                 Grid.Column="1"
                                 Height="40"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 TextChanged="ApiUrlOrModel_TextChanged"/>
                    </Grid>

                    <CheckBox x:Name="WebSearchBox"
                              Content="启用 AI 联网搜索（DeepSeek、Kimi、OpenAI 原生支持）"
                              Margin="0,14,0,0"
                              Style="{StaticResource AppCheckBoxStyle}"/>
                    <TextBlock Text="⚠️ 联网搜索会增加 10-60 秒延迟，仅在搜最新作品时建议开启"
                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                               Margin="20,2,0,0" IsHitTestVisible="False"/>

                    <TextBlock Text="🔍 搜索数据源" Margin="0,18,0,6"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                    <CheckBox x:Name="BangumiSearchBox"
                              Content="Bangumi (bgm.tv) — 中文 ACGN 数据库"
                              Margin="0,0,0,4"
                              Style="{StaticResource AppCheckBoxStyle}"/>
                    <CheckBox x:Name="MALSearchBox"
                              Content="MyAnimeList (Jikan API) — 国际动画数据库"
                              Margin="0,0,0,4"
                              Style="{StaticResource AppCheckBoxStyle}"/>
                    <CheckBox x:Name="AniListSearchBox"
                              Content="AniList (GraphQL) — 详细元数据与标签"
                              Margin="0,0,0,4"
                              Style="{StaticResource AppCheckBoxStyle}"/>

                    <WrapPanel Margin="0,14,0,0">
                        <Button Content="测试连接"
                                Width="96"
                                Height="36"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="TestConnection_Click"/>
                        <Button Content="编辑 AI 提示词"
                                Width="132"
                                Height="36"
                                Margin="0,0,12,0"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="EditPrompt_Click"
                                ToolTip="自定义 AI 助手的系统提示词，调整其行为"/>
                        <TextBlock x:Name="TestStatusText"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚙️ 通用设置" Style="{StaticResource SectionTitleStyle}"/>
                    <CheckBox x:Name="AutoLoginBox"
                              Content="启动时自动登录"
                              Margin="0,0,0,18"
                              Style="{StaticResource AppCheckBoxStyle}"/>
                    <Button Content="退出登录"
                            Width="110"
                            Height="36"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Click="Logout_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="💾 数据设置" Style="{StaticResource SectionTitleStyle}"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Button Content="导入数据"
                                Width="120"
                                Height="36"
                                Margin="0,0,12,0"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="ImportData_Click"/>
                        <Button Content="导出所有数据"
                                Width="132"
                                Height="36"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="ExportData_Click"/>
                    </WrapPanel>
                    <TextBlock Text="数据保存位置"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock x:Name="DataPathText"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,10"/>
                    <Button Content="打开数据文件夹"
                            Width="126"
                            Height="34"
                            HorizontalAlignment="Left"
                            Style="{StaticResource AppGhostButtonStyle}"
                            Click="OpenDataFolder_Click"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🔄 同步追番数据" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="从 Bangumi / B站 同步收藏状态到本地"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Bangumi 用户名" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                        <TextBox x:Name="BangumiUserBox" Grid.Column="1" Height="36" Margin="8,0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 ToolTip="例如: yourname（不是邮箱，是个人页 URL 里的用户名）"/>
                        <Button Grid.Column="2" Content="同步" Width="64" Height="36"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="SyncBangumi_Click"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="B站 UID" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                        <TextBox x:Name="BilibiliUidBox" Grid.Column="1" Height="36" Margin="8,0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 ToolTip="在 B站个人空间 URL 里可以找到，是一串数字"/>
                        <Button Grid.Column="2" Content="同步" Width="64" Height="36"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="SyncBilibili_Click"/>
                    </Grid>

                    <TextBlock x:Name="SyncStatusText" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24">
                <StackPanel>
                    <TextBlock Text="ℹ️ 关于" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="追番手账 AniTechou"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="VersionText"
                               Text="版本"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,6,0,0"/>
                    <TextBlock Text="个人 ACGN 收藏工具"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Button Content="保存设置"
                    Width="120"
                    Height="40"
                    Style="{StaticResource AppPrimaryButtonStyle}"
                    Click="Save_Click"
                    HorizontalAlignment="Center"
                    Margin="0,30,0,20"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
