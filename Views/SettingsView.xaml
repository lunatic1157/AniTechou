<UserControl x:Class="AniTechou.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <TextBlock Text="设置"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#5C4E3D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- API设置 -->
            <Border Background="#F8F4E9" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="🤖 AI 服务设置"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#5C4E3D"
                               Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AI平台" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PlatformBox" Grid.Row="0" Grid.Column="1" Height="32" Margin="0,5" SelectionChanged="Platform_SelectionChanged">
                            <ComboBoxItem Content="DeepSeek" Tag="https://api.deepseek.com/v1"/>
                            <ComboBoxItem Content="智谱AI" Tag="https://open.bigmodel.cn/api/paas/v4"/>
                            <ComboBoxItem Content="阿里云百炼" Tag="https://dashscope.aliyuncs.com/compatible-mode/v1"/>
                            <ComboBoxItem Content="OpenAI" Tag="https://api.openai.com/v1"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                        <PasswordBox x:Name="ApiKeyBox" Grid.Row="1" Grid.Column="1" Height="32" Margin="0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="API地址" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                        <TextBox x:Name="ApiUrlBox" Grid.Row="2" Grid.Column="1" Height="32" Margin="0,5" IsReadOnly="True" Background="#F0E9DD"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="模型" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                        <TextBox x:Name="ModelBox" Grid.Row="3" Grid.Column="1" Height="32" Margin="0,5" IsReadOnly="True" Background="#F0E9DD"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <Button Content="测试连接"
                                Width="90" Height="32"
                                Background="#5C4E3D"
                                Foreground="White"
                                Click="TestConnection_Click"
                                Margin="0,0,10,0"/>
                        <Button Content="编辑AI提示词"
                                Width="110" Height="32"
                                Background="#E0D5C0"
                                Foreground="#5C4E3D"
                                Click="EditPrompt_Click"
                                Margin="0,0,10,0"
                                ToolTip="自定义AI助手的系统提示词，调整其行为"/>
                        <TextBlock x:Name="TestStatusText"
                                   Text=""
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="#7F6E5A"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 通用设置 -->
            <Border Background="#F8F4E9" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚙️ 通用设置"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#5C4E3D"
                               Margin="0,0,0,15"/>

                    <CheckBox x:Name="AutoLoginBox" Content="启动时自动登录" Margin="0,5"/>

                    <Button Content="退出登录"
                            Width="100" Height="32"
                            Background="#E0D5C0"
                            Foreground="#5C4E3D"
                            Click="Logout_Click"
                            Margin="0,15,0,0"/>
                </StackPanel>
            </Border>

            <!-- 数据设置 -->
            <Border Background="#F8F4E9" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="💾 数据设置"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#5C4E3D"
                               Margin="0,0,0,15"/>

                    <Button Content="导出所有数据"
                            Width="120" Height="32"
                            Background="#5C4E3D"
                            Foreground="White"
                            Click="ExportData_Click"
                            Margin="0,5"/>
                    <TextBlock Text="数据保存位置" FontSize="11" Foreground="#A89F91" Margin="0,15,0,0"/>
                    <TextBlock x:Name="DataPathText" FontSize="11" Foreground="#7F6E5A"/>
                    <Button Content="打开数据文件夹"
                            Width="100" Height="28"
                            Background="Transparent"
                            Foreground="#5C4E3D"
                            Click="OpenDataFolder_Click"
                            Margin="0,5"/>
                </StackPanel>
            </Border>

            <!-- 关于 -->
            <Border Background="#F8F4E9" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="ℹ️ 关于"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#5C4E3D"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="追番手账 AniTechou" FontWeight="Bold" Foreground="#5C4E3D"/>
                    <TextBlock Text="版本 1.0" FontSize="11" Foreground="#7F6E5A"/>
                    <TextBlock Text="个人ACGN收藏工具" FontSize="11" Foreground="#7F6E5A" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- 保存按钮 -->
            <Button Content="保存设置"
                    Width="100" Height="35"
                    Background="#5C4E3D"
                    Foreground="White"
                    Click="Save_Click"
                    HorizontalAlignment="Center"
                    Margin="0,30,0,20"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
