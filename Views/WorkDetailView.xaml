<UserControl x:Class="AniTechou.Views.WorkDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- 返回按钮 -->
            <Button Content="← 返回" 
                    Width="80" Height="30"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalAlignment="Left"
                    Click="Back_Click"/>
            
            <!-- 标题 -->
            <TextBlock x:Name="TitleText" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#5C4E3D"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,10"/>
            
            <!-- 封面和基本信息区域（带编辑按钮） -->
            <Grid Margin="0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 封面 -->
                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                        Width="150" Height="200" 
                        Background="#F0E9DD" 
                        CornerRadius="8">
                    <Image x:Name="CoverImage" Stretch="Uniform"/>
                </Border>
                
                <!-- 基本信息 -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,0">
                    <TextBlock x:Name="OriginalTitleText" FontSize="14" Foreground="#7F6E5A" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="TypeText" FontSize="14" Foreground="#5C4E3D" Width="150"/>
                        <TextBlock x:Name="SourceTypeText" FontSize="14" Foreground="#5C4E3D"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="CompanyText" FontSize="14" Foreground="#5C4E3D" Width="150"/>
                        <TextBlock x:Name="OriginalWorkText" FontSize="14" Foreground="#5C4E3D"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="YearText" FontSize="14" Foreground="#5C4E3D" Width="150"/>
                        <TextBlock x:Name="EpisodesText" FontSize="14" Foreground="#5C4E3D"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- 编辑/删除 按钮组 -->
                <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Top">
                    <Button Content="编辑" 
                            Width="60" Height="30"
                            Background="#5C4E3D" 
                            Foreground="White"
                            Margin="0,0,0,5"
                            Click="EditInfo_Click"/>
                    <Button Content="删除" 
                            Width="60" Height="30"
                            Background="Transparent" 
                            Foreground="#D32F2F"
                            BorderBrush="#D32F2F"
                            BorderThickness="1"
                            Click="DeleteWork_Click"/>
                </StackPanel>
            </Grid>
            
            <!-- 简介 -->
            <TextBlock Text="简介" FontSize="16" FontWeight="Bold" Foreground="#5C4E3D" Margin="0,20,0,10"/>
            <TextBlock x:Name="SynopsisTextBlock" TextWrapping="Wrap" Foreground="#7F6E5A"/>

            <!-- 标签区域 -->
            <TextBlock Text="标签" FontSize="16" FontWeight="Bold" Foreground="#5C4E3D" Margin="0,20,0,10"/>
            <WrapPanel x:Name="TagsPanel" Margin="0,5">
                <!-- 标签将动态添加 -->
            </WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBox x:Name="NewTagBox" Width="100" Height="25" Margin="0,0,5,0" ToolTip="输入新标签"/>
                <Button Content="添加标签" Width="70" Height="25" Click="AddTag_Click"/>
            </StackPanel>

            <!-- 个人状态区域 -->
            <Border Background="#F0E9DD" CornerRadius="8" Padding="15" Margin="0,15">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="状态：" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                        <ComboBox x:Name="StatusBox" Grid.Column="1" Width="80" Margin="5,0" SelectedIndex="0">
                            <ComboBoxItem Content="想看"/>
                            <ComboBoxItem Content="在看"/>
                            <ComboBoxItem Content="看过"/>
                        </ComboBox>
                        
                        <TextBlock Grid.Column="2" Text="进度：" Foreground="#5C4E3D" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        <TextBox x:Name="ProgressBox" Grid.Column="3" Width="80" Margin="5,0"/>
                    </Grid>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="评分：" Foreground="#5C4E3D" VerticalAlignment="Center"/>
                        <ComboBox x:Name="RatingBox" Grid.Column="1" Width="120" Margin="5,0" SelectedIndex="0">
                            <ComboBoxItem Content="未评分"/>
                            <ComboBoxItem Content="★☆☆☆☆ (1-2分)"/>
                            <ComboBoxItem Content="★★☆☆☆ (3-4分)"/>
                            <ComboBoxItem Content="★★★☆☆ (5-6分)"/>
                            <ComboBoxItem Content="★★★★☆ (7-8分)"/>
                            <ComboBoxItem Content="★★★★★ (9-10分)"/>
                        </ComboBox>
                    </Grid>
                    
                    <Button Content="更新" 
                            Width="60" Height="30"
                            Background="#5C4E3D" 
                            Foreground="White"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0"
                            Click="Update_Click"/>
                </StackPanel>
            </Border>

            <!-- 关联笔记和关联作品区域 -->
            <Grid Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：关联笔记 -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📝 关联笔记"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#5C4E3D"
                               Margin="0,0,0,15"/>
                    
                    <ItemsControl x:Name="NotesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F4E9" 
                                        CornerRadius="8" 
                                        Padding="15" 
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="NoteItem_Click">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding DisplayTitle}" 
                                                       FontWeight="Bold" 
                                                       Foreground="#5C4E3D"/>
                                            <TextBlock Text="{Binding CreatedTimeDisplay}" 
                                                       Foreground="#A89F91" 
                                                       FontSize="11" 
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Preview}" 
                                                   Foreground="#7F6E5A" 
                                                   Margin="0,5,0,0" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoNotesText"
                               Text="暂无关联笔记"
                               Foreground="#A89F91"
                               FontStyle="Italic"
                               Margin="0,10,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- 右侧：关联作品 -->
                <StackPanel Grid.Column="2">
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="🔗 关联作品"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#5C4E3D"
                                   VerticalAlignment="Center"/>
                        <Button Content="+ 添加关联"
                                Width="80" Height="25"
                                Background="Transparent"
                                Foreground="#7F6E5A"
                                BorderBrush="#E0D5C0"
                                FontSize="12"
                                HorizontalAlignment="Right"
                                Cursor="Hand"
                                Click="AddRelation_Click"/>
                    </Grid>

                    <ItemsControl x:Name="RelationsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F4E9" 
                                        CornerRadius="8" 
                                        Padding="10" 
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="RelatedWork_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- 封面缩略图 -->
                                        <Border CornerRadius="4" ClipToBounds="True" Width="30" Height="40" HorizontalAlignment="Left">
                                            <Image Source="{Binding CoverPath}" Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                                <Setter Property="Source" Value="{x:Null}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Border>

                                        <!-- 信息 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" 
                                                       FontWeight="Bold" 
                                                       Foreground="#5C4E3D"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Info}" 
                                                       Foreground="#A89F91" 
                                                       FontSize="11" 
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        
                                        <!-- 取消关联按钮 -->
                                        <Button Grid.Column="2"
                                                Content="✕"
                                                Width="20" Height="20"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#A89F91"
                                                ToolTip="取消关联"
                                                Click="RemoveRelation_Click"
                                                Tag="{Binding Id}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoRelationsText"
                               Text="暂无关联作品 (同系列/原作)"
                               Foreground="#A89F91"
                               FontStyle="Italic"
                               Margin="0,10,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>