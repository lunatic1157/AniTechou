<UserControl x:Class="AniTechou.Views.WorkDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <Button Content="← 返回" 
                    Width="92" Height="34"
                    Style="{StaticResource AppGhostButtonStyle}"
                    HorizontalAlignment="Left"
                    Click="Back_Click"/>
            
            <!-- 标题 -->
            <TextBlock x:Name="TitleText" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,10"/>
            
            <Border Style="{StaticResource AppSectionCardStyle}" Padding="20" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                        Width="150" Height="200" 
                        Background="{DynamicResource Surface3Brush}" 
                        CornerRadius="12">
                    <Image x:Name="CoverImage" Stretch="Uniform"/>
                </Border>
                
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,0">
                    <TextBlock x:Name="OriginalTitleText" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="TypeText" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Width="150"/>
                        <TextBlock x:Name="SourceTypeText" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="CompanyText" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Width="150"/>
                        <TextBlock x:Name="OriginalWorkText" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="YearText" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" Width="150"/>
                        <TextBlock x:Name="EpisodesText" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Top">
                    <Button Content="编辑" 
                            Width="72" Height="34"
                            Style="{StaticResource AppPrimaryButtonStyle}"
                            Margin="0,0,0,5"
                            Click="EditInfo_Click"/>
                    <Button Content="删除" 
                            Width="72" Height="34"
                            Foreground="{DynamicResource DangerBrush}"
                            BorderBrush="{DynamicResource DangerBrush}"
                            Style="{StaticResource AppGhostButtonStyle}"
                            Click="DeleteWork_Click"/>
                </StackPanel>
            </Grid>
            </Border>
            
            <TextBlock Text="简介" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,20,0,10"/>
            <TextBlock x:Name="SynopsisTextBlock" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"/>

            <TextBlock Text="标签" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,20,0,10"/>
            <WrapPanel x:Name="TagsPanel" Margin="0,5">
            </WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBox x:Name="NewTagBox" Width="120" Height="34" Margin="0,0,8,0" ToolTip="输入新标签" Style="{StaticResource AppTextBoxStyle}"/>
                <Button Content="添加标签" Width="88" Height="34" Style="{StaticResource AppSecondaryButtonStyle}" Click="AddTag_Click"/>
            </StackPanel>

            <Border Style="{StaticResource AppSectionCardStyle}" Padding="18" Margin="0,15">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="状态：" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="StatusBox" Grid.Column="1" Width="100" Margin="5,0" Style="{StaticResource AppComboBoxStyle}"/>
                        
                        <TextBlock Grid.Column="2" Text="进度：" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        <TextBox x:Name="ProgressBox" Grid.Column="3" Width="90" Margin="5,0" Style="{StaticResource AppTextBoxStyle}"/>
                    </Grid>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="评分：" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="RatingBox" Grid.Column="1" Width="140" Margin="5,0" Style="{StaticResource AppComboBoxStyle}"/>
                    </Grid>
                    
                    <Button Content="更新" 
                            Width="72" Height="34"
                            Style="{StaticResource AppPrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0"
                            Click="Update_Click"/>
                </StackPanel>
            </Border>

            <!-- 关联笔记和关联作品区域 -->
            <Grid Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📝 关联笔记"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,15"/>
                    
                    <ItemsControl x:Name="NotesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface2Brush}"
                                        CornerRadius="{DynamicResource CardCornerRadius}" 
                                        Padding="15" 
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="NoteItem_Click">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding DisplayTitle}" 
                                                       FontWeight="Bold" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding CreatedTimeDisplay}" 
                                                       Foreground="{DynamicResource TextMutedBrush}" 
                                                       FontSize="11" 
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Preview}" 
                                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                                   Margin="0,5,0,0" 
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoNotesText"
                               Text="暂无关联笔记"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontStyle="Italic"
                               Margin="0,10,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="🔗 关联作品"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="+ 添加关联"
                                Width="96" Height="32"
                                Style="{StaticResource AppGhostButtonStyle}"
                                FontSize="12"
                                HorizontalAlignment="Right"
                                Click="AddRelation_Click"/>
                    </Grid>

                    <ItemsControl x:Name="RelationsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Surface2Brush}"
                                        CornerRadius="{DynamicResource CardCornerRadius}" 
                                        Padding="10" 
                                        Margin="0,0,0,10"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="RelatedWork_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border CornerRadius="4" ClipToBounds="True" Width="30" Height="40" HorizontalAlignment="Left">
                                            <Image Source="{Binding CoverPath}" Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                                <Setter Property="Source" Value="{x:Null}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" 
                                                       FontWeight="Bold" 
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Info}" 
                                                       Foreground="{DynamicResource TextMutedBrush}" 
                                                       FontSize="11" 
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="2"
                                                Content="✕"
                                                Width="20" Height="20"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{DynamicResource TextMutedBrush}"
                                                ToolTip="取消关联"
                                                Click="RemoveRelation_Click"
                                                Tag="{Binding Id}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoRelationsText"
                               Text="暂无关联作品 (同系列/原作)"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontStyle="Italic"
                               Margin="0,10,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
