<UserControl x:Class="AniTechou.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WindowBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">

            <!-- 标题 -->
            <TextBlock Text="个人主页"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- 头像和昵称区域 -->
            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 头像 -->
                    <Border Grid.Column="0"
                            Width="80" Height="80"
                            Background="{DynamicResource AccentSoftBrush}"
                            CornerRadius="40"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            MouseLeftButtonUp="Avatar_Click">
                        <Border.ToolTip>点击上传/修改头像</Border.ToolTip>
                        <Grid>
                            <TextBlock x:Name="DefaultAvatarText"
                                       Text="👤"
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Image x:Name="AvatarImage"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Clip>
                                    <EllipseGeometry RadiusX="40" RadiusY="40" Center="40,40"/>
                                </Image.Clip>
                            </Image>
                        </Grid>
                    </Border>

                    <!-- 昵称和加入时间 -->
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <Border Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource InputCornerRadius}"
                                Padding="12,8"
                                HorizontalAlignment="Left"
                                Cursor="Hand"
                                ToolTip="点击修改昵称"
                                MouseLeftButtonUp="EditNickname_Click">
                            <TextBlock x:Name="NicknameText"
                                       Text="ACGN爱好者"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <TextBlock x:Name="JoinDateText"
                                   Text="加入时间：--"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 统计看板 -->
            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📊 统计看板"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Surface2Brush}" CornerRadius="{DynamicResource CardCornerRadius}" Padding="18" Margin="0,0,10,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="AnimeCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="动画" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource Surface2Brush}" CornerRadius="{DynamicResource CardCornerRadius}" Padding="18" Margin="5,0,5,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="MangaCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="漫画" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{DynamicResource Surface2Brush}" CornerRadius="{DynamicResource CardCornerRadius}" Padding="18" Margin="10,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="GameCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="游戏" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Surface2Brush}" CornerRadius="{DynamicResource CardCornerRadius}" Padding="18" Margin="0,0,10,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalWorksText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="总作品数" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource Surface2Brush}" CornerRadius="{DynamicResource CardCornerRadius}" Padding="18" Margin="10,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalNotesText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="总笔记数" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 年度总结 -->
            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📅 年度总结"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,15"/>

                    <ItemsControl x:Name="YearStatsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Year}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                                    <!-- 简易柱状图 -->
                                    <Border Grid.Column="1"
                                            Height="24"
                                            Background="{DynamicResource AccentSoftBrush}"
                                            CornerRadius="4"
                                            Margin="5,0,5,0"
                                            HorizontalAlignment="Left"
                                            Width="{Binding BarWidth}"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CountDisplay}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoYearDataText"
                               Text="暂无数据"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- 标签云 -->
            <Border Style="{StaticResource AppSectionCardStyle}" Padding="24">
                <StackPanel>
                    <TextBlock Text="🏷️ 标签云"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,15"/>

                    <WrapPanel x:Name="TagCloudPanel" HorizontalAlignment="Center">
                        <!-- 标签动态添加 -->
                    </WrapPanel>

                    <TextBlock x:Name="NoTagText"
                               Text="暂无标签"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
