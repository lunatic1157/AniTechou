<UserControl x:Class="AniTechou.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">

            <!-- 标题 -->
            <TextBlock Text="个人主页"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#5C4E3D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- 头像和昵称区域 -->
            <Border Background="#F8F4E9" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 头像 -->
                    <Border Grid.Column="0"
                            Width="80" Height="80"
                            Background="#E0D5C0"
                            CornerRadius="40"
                            HorizontalAlignment="Left"
                            Cursor="Hand"
                            MouseLeftButtonUp="Avatar_Click">
                        <Border.ToolTip>点击上传/修改头像</Border.ToolTip>
                        <Grid>
                            <TextBlock x:Name="DefaultAvatarText"
                                       Text="👤"
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Image x:Name="AvatarImage"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Clip>
                                    <EllipseGeometry RadiusX="40" RadiusY="40" Center="40,40"/>
                                </Image.Clip>
                            </Image>
                        </Grid>
                    </Border>

                    <!-- 昵称和加入时间 -->
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBox x:Name="NicknameBox"
                                 Text="ACGN爱好者"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 Foreground="#5C4E3D"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsReadOnly="True"/>
                        <Button Content="编辑昵称"
                                Width="70" Height="25"
                                Background="Transparent"
                                Foreground="#7F6E5A"
                                BorderThickness="0"
                                FontSize="11"
                                Click="EditNickname_Click"
                                HorizontalAlignment="Left"/>
                        <TextBlock x:Name="JoinDateText"
                                   Text="加入时间：--"
                                   FontSize="11"
                                   Foreground="#A89F91"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 统计看板 -->
            <Border Background="#F8F4E9" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📊 统计看板"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#5C4E3D"
                               Margin="0,0,0,15"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="AnimeCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                <TextBlock Text="动画" FontSize="12" Foreground="#A89F91" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="5,0,5,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="MangaCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                <TextBlock Text="漫画" FontSize="12" Foreground="#A89F91" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="GameCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                <TextBlock Text="游戏" FontSize="12" Foreground="#A89F91" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalWorksText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                <TextBlock Text="总作品数" FontSize="12" Foreground="#A89F91" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalNotesText" Text="0" FontSize="28" FontWeight="Bold" Foreground="#5C4E3D" HorizontalAlignment="Center"/>
                                <TextBlock Text="总笔记数" FontSize="12" Foreground="#A89F91" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 年度总结 -->
            <Border Background="#F8F4E9" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="📅 年度总结"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#5C4E3D"
                               Margin="0,0,0,15"/>

                    <ItemsControl x:Name="YearStatsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Year}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="#5C4E3D"/>

                                    <!-- 简易柱状图 -->
                                    <Border Grid.Column="1"
                                            Height="24"
                                            Background="#E0D5C0"
                                            CornerRadius="4"
                                            Margin="5,0,5,0"
                                            HorizontalAlignment="Left"
                                            Width="{Binding BarWidth}"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CountDisplay}"
                                               FontSize="11"
                                               Foreground="#7F6E5A"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoYearDataText"
                               Text="暂无数据"
                               FontSize="12"
                               Foreground="#A89F91"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- 标签云 -->
            <Border Background="#F8F4E9" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="🏷️ 标签云"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#5C4E3D"
                               Margin="0,0,0,15"/>

                    <WrapPanel x:Name="TagCloudPanel" HorizontalAlignment="Center">
                        <!-- 标签动态添加 -->
                    </WrapPanel>

                    <TextBlock x:Name="NoTagText"
                               Text="暂无标签"
                               FontSize="12"
                               Foreground="#A89F91"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
