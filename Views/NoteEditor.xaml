<UserControl x:Class="AniTechou.Views.NoteEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="写笔记"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#5C4E3D"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- 标题输入框 -->
        <TextBox x:Name="TitleBox"
                 Height="35"
                 Margin="0,0,0,10"
                 FontSize="14"
                 FontWeight="Bold"
                 Foreground="#5C4E3D"
                 ToolTip="笔记标题（可选）"/>

        <!-- 关联作品 -->
        <StackPanel Grid.Row="1" Margin="0,5">
            <TextBlock Text="关联作品" FontSize="14" FontWeight="Bold" Foreground="#5C4E3D"/>
            <WrapPanel x:Name="WorksPanel" Margin="0,5"/>
            <Button Content="+ 添加关联" 
                    Width="100" Height="30"
                    Background="#E0D5C0"
                    Click="AddWork_Click"/>
        </StackPanel>
        
        <!-- 标签 -->
        <StackPanel Grid.Row="2" Margin="0,10">
            <TextBlock Text="标签" FontSize="14" FontWeight="Bold" Foreground="#5C4E3D"/>
            <WrapPanel x:Name="TagsPanel" Margin="0,5"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="NewTagBox" Width="100" Height="25" Margin="0,0,5,0"/>
                <Button Content="添加标签" Width="70" Height="25" Click="AddTag_Click"/>
            </StackPanel>
        </StackPanel>
        
        <!-- 笔记内容 -->
        <StackPanel Grid.Row="3" Margin="0,10">
            <TextBlock Text="内容" FontSize="14" FontWeight="Bold" Foreground="#5C4E3D"/>
            <TextBox x:Name="ContentBox" Height="200" TextWrapping="Wrap" AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto" Margin="0,5"/>
        </StackPanel>
        
        <!-- 按钮 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Content="保存" Width="80" Height="35" Background="#5C4E3D" Foreground="White" Click="Save_Click" Margin="0,0,10,0"/>
            <Button Content="取消" Width="80" Height="35" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</UserControl>