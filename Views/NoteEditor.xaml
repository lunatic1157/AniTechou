<UserControl x:Class="AniTechou.Views.NoteEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AniTechou.Views"
             Background="{DynamicResource WindowBackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="PaletteSwatchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource Surface1Brush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="SaveCommand_Executed"/>
        <CommandBinding Command="ApplicationCommands.Undo" Executed="UndoCommand_Executed"/>
        <CommandBinding Command="ApplicationCommands.Redo" Executed="RedoCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.ToggleBoldCommand}" Executed="ToggleBoldCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.ToggleItalicCommand}" Executed="ToggleItalicCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.ToggleUnderlineCommand}" Executed="ToggleUnderlineCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.Heading1Command}" Executed="Heading1Command_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.Heading2Command}" Executed="Heading2Command_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.Heading3Command}" Executed="Heading3Command_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.BulletedListCommand}" Executed="BulletedListCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.NumberedListCommand}" Executed="NumberedListCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.InsertLinkCommand}" Executed="InsertLinkCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.InsertImageCommand}" Executed="InsertImageCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.AlignLeftCommand}" Executed="AlignLeftCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.AlignCenterCommand}" Executed="AlignCenterCommand_Executed"/>
        <CommandBinding Command="{x:Static views:NoteEditor.AlignRightCommand}" Executed="AlignRightCommand_Executed"/>
    </UserControl.CommandBindings>

    <UserControl.InputBindings>
        <KeyBinding Command="ApplicationCommands.Save" Gesture="Ctrl+S"/>
        <KeyBinding Command="ApplicationCommands.Undo" Gesture="Ctrl+Z"/>
        <KeyBinding Command="ApplicationCommands.Redo" Gesture="Ctrl+Y"/>

        <KeyBinding Command="{x:Static views:NoteEditor.ToggleBoldCommand}" Gesture="Ctrl+B"/>
        <KeyBinding Command="{x:Static views:NoteEditor.ToggleItalicCommand}" Gesture="Ctrl+I"/>
        <KeyBinding Command="{x:Static views:NoteEditor.ToggleUnderlineCommand}" Gesture="Ctrl+U"/>

        <KeyBinding Command="{x:Static views:NoteEditor.Heading1Command}" Gesture="Ctrl+1"/>
        <KeyBinding Command="{x:Static views:NoteEditor.Heading2Command}" Gesture="Ctrl+2"/>
        <KeyBinding Command="{x:Static views:NoteEditor.Heading3Command}" Gesture="Ctrl+3"/>

        <KeyBinding Command="{x:Static views:NoteEditor.BulletedListCommand}" Gesture="Ctrl+Shift+L"/>
        <KeyBinding Command="{x:Static views:NoteEditor.NumberedListCommand}" Gesture="Ctrl+Shift+O"/>

        <KeyBinding Command="{x:Static views:NoteEditor.InsertLinkCommand}" Gesture="Ctrl+K"/>
        <KeyBinding Command="{x:Static views:NoteEditor.InsertImageCommand}" Gesture="Ctrl+Shift+I"/>
    </UserControl.InputBindings>

        <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Grid.Column="0"
                    Content="← 返回"
                    Width="92"
                    Height="34"
                    Style="{StaticResource AppGhostButtonStyle}"
                    Click="Back_Click"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="💾 保存" Width="92" Height="34" Margin="0,0,8,0" Style="{StaticResource AppPrimaryButtonStyle}" Click="SaveButton_Click"/>
                <Button Content="↩ 撤销" Width="92" Height="34" Margin="0,0,8,0" Style="{StaticResource AppSecondaryButtonStyle}" Click="UndoButton_Click"/>
                <Button Content="↪ 重做" Width="92" Height="34" Margin="0,0,8,0" Style="{StaticResource AppSecondaryButtonStyle}" Click="RedoButton_Click"/>
                <ToggleButton x:Name="AutoSaveToggle"
                              Content="自动保存"
                              IsChecked="True"
                              Width="96"
                              Height="34"
                              Margin="2,0,0,0"
                              Style="{StaticResource AppToggleButtonStyle}"/>
                <TextBlock x:Name="SaveStatusText"
                           Text="已保存"
                           Margin="10,0,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Border Background="{DynamicResource Surface2Brush}" CornerRadius="{DynamicResource CardCornerRadius}" Padding="10">
                <WrapPanel>
                <Button Content="B" Style="{StaticResource AppToolbarButtonStyle}" Click="BoldButton_Click"/>
                <Button Content="I" Style="{StaticResource AppToolbarButtonStyle}" Click="ItalicButton_Click"/>
                <Button Content="U" Style="{StaticResource AppToolbarButtonStyle}" Margin="0,0,12,0" Click="UnderlineButton_Click"/>
                <Button Content="H1" Width="42" Style="{StaticResource AppToolbarButtonStyle}" Click="H1Button_Click"/>
                <Button Content="H2" Width="42" Style="{StaticResource AppToolbarButtonStyle}" Click="H2Button_Click"/>
                <Button Content="H3" Width="42" Style="{StaticResource AppToolbarButtonStyle}" Margin="0,0,12,0" Click="H3Button_Click"/>
                <Button Content="•" Style="{StaticResource AppToolbarButtonStyle}" Click="BulletedListButton_Click"/>
                <Button Content="1." Style="{StaticResource AppToolbarButtonStyle}" Margin="0,0,12,0" Click="NumberedListButton_Click"/>
                <Button Content="左" Style="{StaticResource AppToolbarButtonStyle}" Click="AlignLeftButton_Click"/>
                <Button Content="中" Style="{StaticResource AppToolbarButtonStyle}" Click="AlignCenterButton_Click"/>
                <Button Content="右" Style="{StaticResource AppToolbarButtonStyle}" Margin="0,0,12,0" Click="AlignRightButton_Click"/>
                <Button x:Name="TextColorButton" Content="A" Style="{StaticResource AppToolbarButtonStyle}" Click="TextColorButton_Click" ToolTip="文字颜色"/>
                <Button x:Name="HighlightButton" Content="🖍" Style="{StaticResource AppToolbarButtonStyle}" Margin="0,0,12,0" Click="HighlightButton_Click" ToolTip="高亮颜色"/>
                <Button Content="🔗" Style="{StaticResource AppToolbarButtonStyle}" Click="LinkButton_Click"/>
                <Button Content="🖼️" Style="{StaticResource AppToolbarButtonStyle}" Click="ImageButton_Click"/>
                </WrapPanel>
            </Border>

            <Popup x:Name="TextColorPopup"
                   PlacementTarget="{Binding ElementName=TextColorButton}"
                   Placement="Bottom"
                   VerticalOffset="8"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="{DynamicResource Surface1Brush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Effect="{DynamicResource PopupShadow}">
                    <StackPanel>
                        <TextBlock Text="文字颜色" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <WrapPanel x:Name="TextColorPalettePanel"/>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="HighlightPopup"
                   PlacementTarget="{Binding ElementName=HighlightButton}"
                   Placement="Bottom"
                   VerticalOffset="8"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="{DynamicResource Surface1Brush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Effect="{DynamicResource PopupShadow}">
                    <StackPanel>
                        <TextBlock Text="高亮颜色" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <WrapPanel x:Name="HighlightPalettePanel"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <TextBox x:Name="TitleBox"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderThickness="0"
                     Background="Transparent"
                     TextChanged="TitleBox_TextChanged">
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="ApplicationCommands.Cut" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="剪切"/>
                        <MenuItem Command="ApplicationCommands.Copy" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="复制"/>
                        <MenuItem Command="ApplicationCommands.Paste" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="粘贴"/>
                        <Separator/>
                        <MenuItem Command="ApplicationCommands.SelectAll" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="全选"/>
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
            <TextBlock x:Name="TitlePlaceholder"
                       Text="无标题"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="2,0,0,0"/>
        </Grid>

        <Grid Grid.Row="3">
            <Border Background="{DynamicResource Surface1Brush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="{DynamicResource CardCornerRadius}">
                <RichTextBox x:Name="RichEditor"
                             AcceptsReturn="True"
                             AllowDrop="True"
                             IsDocumentEnabled="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Background="{DynamicResource Surface1Brush}"
                             BorderThickness="0"
                             Padding="10"
                             PreviewDragOver="RichEditor_PreviewDragOver"
                             Drop="RichEditor_Drop"
                             SelectionChanged="RichEditor_SelectionChanged"
                             TextChanged="RichEditor_TextChanged">
                    <RichTextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Command="ApplicationCommands.Cut" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="剪切"/>
                            <MenuItem Command="ApplicationCommands.Copy" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="复制"/>
                            <MenuItem Command="ApplicationCommands.Paste" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="粘贴"/>
                            <Separator/>
                            <MenuItem Command="ApplicationCommands.SelectAll" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="全选"/>
                        </ContextMenu>
                    </RichTextBox.ContextMenu>
                    <FlowDocument PagePadding="0">
                        <Paragraph></Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="关联作品" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <DockPanel Margin="0,6,0,0">
                <Button Content="➕ 添加作品" DockPanel.Dock="Right" Width="104" Height="34" Style="{StaticResource AppSecondaryButtonStyle}" Click="AddWork_Click"/>
                <WrapPanel x:Name="WorksPanel" VerticalAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,12,0,0">
            <TextBlock Text="笔记标签" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <DockPanel Margin="0,6,0,0">
                <Grid DockPanel.Dock="Right" Width="220">
                    <TextBox x:Name="NewTagBox"
                             Height="34"
                             Style="{StaticResource AppTextBoxStyle}"
                             TextChanged="NewTagBox_TextChanged"
                             KeyDown="NewTagBox_KeyDown"
                             LostFocus="NewTagBox_LostFocus">
                        <TextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="ApplicationCommands.Cut" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="剪切"/>
                                <MenuItem Command="ApplicationCommands.Copy" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="复制"/>
                                <MenuItem Command="ApplicationCommands.Paste" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="粘贴"/>
                                <Separator/>
                                <MenuItem Command="ApplicationCommands.SelectAll" CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Header="全选"/>
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>
                    <Popup x:Name="TagSuggestPopup"
                           PlacementTarget="{Binding ElementName=NewTagBox}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="{DynamicResource Surface1Brush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Effect="{DynamicResource PopupShadow}">
                            <ListBox x:Name="TagSuggestList"
                                     MinWidth="220"
                                     MaxHeight="200"
                                     SelectionChanged="TagSuggestList_SelectionChanged"/>
                        </Border>
                    </Popup>
                </Grid>
                <WrapPanel x:Name="TagsPanel" VerticalAlignment="Center"/>
            </DockPanel>
        </StackPanel>
    </Grid>
</UserControl>
