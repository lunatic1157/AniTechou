<Window x:Class="AniTechou.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册新账号 · 追番手账"
        Width="430" Height="430"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Microsoft YaHei"
        ResizeMode="NoResize">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="注册新账号"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,18"/>

        <Border Grid.Row="1" Style="{StaticResource AppSectionCardStyle}" Padding="22">
            <StackPanel>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="用户名"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="UserNameBox"
                             Height="40"
                             Style="{StaticResource AppTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="密码"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Height="40"
                                 Style="{StaticResource AppPasswordBoxStyle}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,22">
                    <TextBlock Text="确认密码"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Height="40"
                                 Style="{StaticResource AppPasswordBoxStyle}"/>
                </StackPanel>

                <Button Content="注册"
                        Width="100"
                        Height="38"
                        HorizontalAlignment="Center"
                        Style="{StaticResource AppPrimaryButtonStyle}"
                        Click="Register_Click"/>

                <TextBlock Text="已有账号？返回登录"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           Cursor="Hand"
                           MouseLeftButtonDown="BackToLogin_Click"/>

                <TextBlock x:Name="MessageText"
                           Text=""
                           Foreground="{DynamicResource DangerBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
