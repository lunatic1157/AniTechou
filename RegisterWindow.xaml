<Window x:Class="AniTechou.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册新账号 · 追番手账"
        Width="400" Height="350"
        WindowStartupLocation="CenterScreen"
        Background="#F8F4E9"
        FontFamily="Microsoft YaHei"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="RoundButton" TargetType="Button">
            <Setter Property="Background" Value="#5C4E3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7F6E5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        
        <Style x:Key="PasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="注册新账号" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Foreground="#5C4E3D"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- 用户名 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="用户名" 
                       FontSize="14" 
                       Foreground="#5C4E3D"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="UserNameBox"
                     Style="{StaticResource InputBox}"
                     Background="White"/>
        </StackPanel>

        <!-- 密码 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="密码" 
                       FontSize="14" 
                       Foreground="#5C4E3D"
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox"
                         Style="{StaticResource PasswordBox}"
                         Background="White"/>
        </StackPanel>

        <!-- 确认密码 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <TextBlock Text="确认密码" 
                       FontSize="14" 
                       Foreground="#5C4E3D"
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox"
                         Style="{StaticResource PasswordBox}"
                         Background="White"/>
        </StackPanel>

        <!-- 注册按钮 -->
        <Button Grid.Row="4" 
                Content="注册"
                Style="{StaticResource RoundButton}"
                HorizontalAlignment="Center"
                Click="Register_Click"/>

        <!-- 返回登录链接 -->
        <TextBlock Grid.Row="5" 
                   Text="已有账号？返回登录"
                   FontSize="12"
                   Foreground="#7F6E5A"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,0"
                   Cursor="Hand"
                   MouseLeftButtonDown="BackToLogin_Click"/>

        <!-- 错误信息 -->
        <TextBlock Grid.Row="6" 
                   x:Name="MessageText"
                   Text=""
                   Foreground="Red"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>