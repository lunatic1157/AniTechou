<Window x:Class="AniTechou.Windows.EditWorkInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑作品信息"
        Width="500" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="#F8F4E9">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="编辑作品信息" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#5C4E3D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="标题" Foreground="#5C4E3D" Margin="5"/>
                <TextBox x:Name="TitleBox" Grid.Row="0" Grid.Column="1" Margin="5"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="原名" Foreground="#5C4E3D" Margin="5"/>
                <TextBox x:Name="OriginalTitleBox" Grid.Row="1" Grid.Column="1" Margin="5"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="类型" Foreground="#5C4E3D" Margin="5"/>
                <ComboBox x:Name="TypeBox" Grid.Row="2" Grid.Column="1" Margin="5">
                    <ComboBoxItem Content="Anime"/>
                    <ComboBoxItem Content="Manga"/>
                    <ComboBoxItem Content="LightNovel"/>
                    <ComboBoxItem Content="Game"/>
                </ComboBox>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="制作公司" Foreground="#5C4E3D" Margin="5"/>
                <TextBox x:Name="CompanyBox" Grid.Row="3" Grid.Column="1" Margin="5"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="年份" Foreground="#5C4E3D" Margin="5" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="5">
                    <TextBox x:Name="YearBox" Width="80" Height="30" ToolTip="年份"/>
                    <ComboBox x:Name="SeasonBox" Width="60" Height="30" Margin="5,0,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="春"/>
                        <ComboBoxItem Content="夏"/>
                        <ComboBoxItem Content="秋"/>
                        <ComboBoxItem Content="冬"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="集数/卷数" Foreground="#5C4E3D" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="EpisodesBox" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>
                
                <TextBlock Grid.Row="6" Grid.Column="0" Text="简介" Foreground="#5C4E3D" Margin="5"/>
                <TextBox x:Name="SynopsisBox" Grid.Row="6" Grid.Column="1" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="5"/>
            </Grid>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
                <Button Content="保存" Width="80" Height="35" Background="#5C4E3D" Foreground="White" Click="Save_Click" Margin="0,0,10,0"/>
                <Button Content="取消" Width="80" Height="35" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>