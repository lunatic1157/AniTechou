<Window x:Class="AniTechou.Windows.LinkInsertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="插入链接"
        Width="460" Height="260"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="插入链接"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,18"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="文字"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,12"/>
        <TextBox x:Name="LinkTextBox"
                 Grid.Row="1" Grid.Column="1"
                 Height="40"
                 Margin="0,0,0,12"
                 Style="{StaticResource AppTextBoxStyle}"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="URL"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,12,12"/>
        <TextBox x:Name="LinkUrlBox"
                 Grid.Row="2" Grid.Column="1"
                 Height="40"
                 Margin="0,0,0,12"
                 Style="{StaticResource AppTextBoxStyle}"/>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="确定"
                    Width="88" Height="36"
                    Style="{StaticResource AppPrimaryButtonStyle}"
                    Click="OK_Click"
                    Margin="0,0,10,0"/>
            <Button Content="取消"
                    Width="88" Height="36"
                    Style="{StaticResource AppSecondaryButtonStyle}"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>

