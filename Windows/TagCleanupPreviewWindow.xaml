<Window x:Class="AniTechou.Windows.TagCleanupPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="标签清理预览"
        Width="920"
        Height="680"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="标签清理预览"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="预览不会修改数据。应用清理前会自动导出可移植备份。"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource AppSectionCardStyle}"
                Padding="16"
                Margin="0,18,0,14">
            <StackPanel>
                <TextBlock x:Name="SummaryText"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="BackupText"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{DynamicResource Surface1Brush}">
            <ListView x:Name="PreviewList"
                      BorderThickness="0"
                      Background="Transparent">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="作品" Width="190" DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="年份" Width="70" DisplayMemberBinding="{Binding Year}"/>
                        <GridViewColumn Header="制作" Width="130" DisplayMemberBinding="{Binding Company}"/>
                        <GridViewColumn Header="将删除" Width="240" DisplayMemberBinding="{Binding RemoveDisplay}"/>
                        <GridViewColumn Header="将新增/转换" Width="210" DisplayMemberBinding="{Binding AddDisplay}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button x:Name="ApplyButton"
                    Content="备份并应用清理"
                    Width="140"
                    Height="38"
                    Margin="0,0,12,0"
                    Style="{StaticResource AppPrimaryButtonStyle}"
                    Click="Apply_Click"/>
            <Button Content="关闭"
                    Width="96"
                    Height="38"
                    Style="{StaticResource AppSecondaryButtonStyle}"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
