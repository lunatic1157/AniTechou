<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Thickness x:Key="Spacing4">4</Thickness>
    <Thickness x:Key="Spacing8">8</Thickness>
    <Thickness x:Key="Spacing12">12</Thickness>
    <Thickness x:Key="Spacing16">16</Thickness>
    <Thickness x:Key="Spacing24">24</Thickness>

    <CornerRadius x:Key="ButtonCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="InputCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">14</CornerRadius>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F4F7FB"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Surface3Brush" Color="#EEF2F7"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D8E0EA"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#E7EDF5"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#4F9CFF"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DCEBFF"/>
    <SolidColorBrush x:Key="AccentStrongBrush" Color="#2A7AE3"/>
    <SolidColorBrush x:Key="AccentContrastBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#E35D6A"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#18A573"/>
    <SolidColorBrush x:Key="ShadowBrush" Color="#220F172A"/>

    <DropShadowEffect x:Key="CardHoverShadow"
                      BlurRadius="20"
                      Direction="270"
                      ShadowDepth="4"
                      Opacity="0.18"
                      Color="#220F172A"/>
    <DropShadowEffect x:Key="PopupShadow"
                      BlurRadius="18"
                      Direction="270"
                      ShadowDepth="3"
                      Opacity="0.2"
                      Color="#260F172A"/>
</ResourceDictionary>
